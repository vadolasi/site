{
  "env": {
    "es2021": true,
    "jest": true
  },
  "extends": [
    "standard",
    "plugin:prettier/recommended",
    "plugin:vue/vue3-recommended",
    "plugin:cypress/recommended"
  ],
  "parser": "vue-eslint-parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint",
    "prettier",
    "cypress"
  ],
  "rules": {
    "vue/multi-word-component-names": ["error", {
      "ignores": ["index", "default"]
    }]
  }
}
